rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserSetting(data) {
      return data.keys().hasAll(['userId', 'settings', 'tags', 'updatedAt']) &&
             data.userId is string &&
             (data.keys().hasAll(['email']) == false || data.email is string) &&
             data.settings is map &&
             data.tags is list && data.tags.size() <= 100 &&
             data.updatedAt is string;
    }

    function isValidWorkspace(data) {
      return data.keys().hasAll(['userId', 'id', 'name', 'createdAt', 'order']) &&
             data.userId is string &&
             data.id is string &&
             data.name is string && data.name.size() <= 100 &&
             data.createdAt is string &&
             data.order is number &&
             (data.keys().hasAll(['icon']) == false || data.icon is string);
    }

    function isValidCollection(data) {
      return data.keys().hasAll(['userId', 'id', 'workspaceId', 'name', 'createdAt', 'order']) &&
             data.userId is string &&
             data.id is string &&
             data.workspaceId is string &&
             data.name is string && data.name.size() <= 100 &&
             data.createdAt is string &&
             data.order is number &&
             (data.keys().hasAll(['icon']) == false || data.icon is string);
    }

    function isValidNote(data) {
      return data.keys().hasAll(['userId', 'id', 'workspaceId', 'collectionId', 'title', 'content', 'tags', 'pinned', 'createdAt', 'updatedAt', 'wordCount']) &&
             data.userId is string &&
             data.id is string &&
             data.workspaceId is string &&
             data.collectionId is string &&
             data.title is string && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 1048000 &&
             data.tags is list && data.tags.size() <= 100 &&
             data.pinned is bool &&
             (data.keys().hasAll(['starred']) == false || data.starred is bool) &&
             data.createdAt is string &&
             data.updatedAt is string &&
             data.wordCount is number &&
             (data.keys().hasAll(['isDeleted']) == false || data.isDeleted is bool) &&
             (data.keys().hasAll(['deletedAt']) == false || data.deletedAt is string) &&
             (data.keys().hasAll(['headerMeta']) == false || data.headerMeta is map) &&
             (data.keys().hasAll(['images']) == false || data.images is list) &&
             (data.keys().hasAll(['attachments']) == false || data.attachments is list) &&
             (data.keys().hasAll(['charts']) == false || data.charts is list);
    }

    function isSameEmail(emailStr) { return isSignedIn() && request.auth.token.email != null && request.auth.token.email == emailStr; }
    
    match /users/{userId} {
      match /settings/{settingId} {
        allow read: if isOwner(userId) || isSameEmail(resource.data.email);
        allow create: if isOwner(userId) && isValidId(settingId) && isValidUserSetting(incoming()) && incoming().userId == userId && incoming().keys().size() <= 6;
        allow update: if isOwner(userId) && isValidId(settingId) && isValidUserSetting(incoming()) && incoming().userId == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'tags', 'updatedAt', 'userId', 'email']);
        allow delete: if isOwner(userId) || isSameEmail(existing().email);
      }
      
      match /workspaces/{workspaceId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(workspaceId) && isValidWorkspace(incoming()) && incoming().userId == userId && incoming().keys().size() <= 6;
        allow update: if isOwner(userId) && isValidId(workspaceId) && isValidWorkspace(incoming()) && incoming().userId == existing().userId && incoming().id == existing().id && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'icon', 'order', 'userId']);
        allow delete: if isOwner(userId);
      }

      match /collections/{collectionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(collectionId) && isValidCollection(incoming()) && incoming().userId == userId && incoming().keys().size() <= 7;
        allow update: if isOwner(userId) && isValidId(collectionId) && isValidCollection(incoming()) && incoming().userId == existing().userId && incoming().id == existing().id && incoming().workspaceId == existing().workspaceId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'icon', 'order', 'userId']);
        allow delete: if isOwner(userId);
      }
      
      match /notes/{noteId} {
        allow read: if isOwner(userId) || (isSignedIn() && exists(/databases/$(database)/documents/users/$(userId)/settings/default) && isSameEmail(get(/databases/$(database)/documents/users/$(userId)/settings/default).data.email));
        allow create: if isOwner(userId) && isValidId(noteId) && isValidNote(incoming()) && incoming().userId == userId && incoming().keys().size() <= 17;
        allow update: if isOwner(userId) && isValidId(noteId) && isValidNote(incoming()) && incoming().userId == existing().userId && incoming().id == existing().id && incoming().diff(existing()).affectedKeys().hasOnly(['workspaceId', 'collectionId', 'title', 'content', 'tags', 'pinned', 'starred', 'isDeleted', 'deletedAt', 'updatedAt', 'wordCount', 'headerMeta', 'images', 'attachments', 'charts', 'userId']);
        allow delete: if isOwner(userId) || (isSignedIn() && exists(/databases/$(database)/documents/users/$(userId)/settings/default) && isSameEmail(get(/databases/$(database)/documents/users/$(userId)/settings/default).data.email));
      }
    }
  }
}
